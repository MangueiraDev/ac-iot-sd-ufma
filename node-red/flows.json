  {
    "id": "ic_func_direct_post",
    "type": "function",
    "z": "ic_tab",
    "name": "Montar POST InterSCity direto",
    "func": "const rooms = {\n    sala01: { uuid: '00000000-0000-4000-8000-000000000101', temperatura: 34.2, umidade: 61, luminosidade: 901, setpoint_ac: 20 },\n    sala02: { uuid: '00000000-0000-4000-8000-000000000102', temperatura: 29.9, umidade: 57, luminosidade: 650, setpoint_ac: 22 },\n    sala03: { uuid: '00000000-0000-4000-8000-000000000103', temperatura: 25.5, umidade: 53, luminosidade: 420, setpoint_ac: 23 }\n};\nconst sala = msg.sala || 'sala01';\nconst room = rooms[sala] || rooms.sala01;\nconst date = new Date().toISOString();\nmsg.method = 'POST';\nmsg.url = `http://interscity-resource-adaptor:3000/resources/${room.uuid}/data`;\nmsg.headers = { 'Content-Type': 'application/json' };\nmsg.payload = {\n    data: {\n        temperatura: [{ value: room.temperatura, date }],\n        umidade: [{ value: room.umidade, date }],\n        luminosidade: [{ value: room.luminosidade, date }],\n        presenca: [{ value: true, date }],\n        status_ac: [{ value: 'ligado', date }],\n        setpoint_ac: [{ value: room.setpoint_ac, date }],\n        status_luz: [{ value: 'ligado', date }],\n        modo_ac: [{ value: 'ativo', date }]\n    }\n};\nreturn msg;",
    "outputs": 1,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
