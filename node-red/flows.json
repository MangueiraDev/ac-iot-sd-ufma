  {
    "id": "func_auto",
    "type": "function",
    "z": "tab_auto",
    "name": "Automação AC (Temp + Presença + Timer 1min)",
    "func": "var payload = msg.payload;\nif (typeof payload === 'string') {\n    try { payload = JSON.parse(payload); }\n    catch(e) { return null; }\n}\nif (!payload) return null;\nif (payload.hasOwnProperty('comando')) return null;\nif (payload.modo_ac === 'desativado') return null;\n\nvar id_sala = payload.id_sala;\nif (!id_sala && msg.topic) {\n    var p = msg.topic.split('/');\n    if (p.length >= 2) id_sala = p[1];\n}\nif (!id_sala || id_sala === 'all') return null;\n\nvar temp = Number(payload.temperatura);\nif (!Number.isFinite(temp)) return null;\n\nvar set = Number.isFinite(Number(payload.setpoint_ac)) ? Number(payload.setpoint_ac) : 22;\nvar m = 2;\nvar stAC = payload.status_ac;\nvar pres = payload.presenca === true;\nvar now = Date.now();\n\nvar ctx = context.get('salas') || {};\nif (!ctx[id_sala]) ctx[id_sala] = { lastPres: now, done: false };\nvar s = ctx[id_sala];\nif (pres) { s.lastPres = now; s.done = false; }\ncontext.set('salas', ctx);\n\nvar acao = null, razao = '';\n\nif (pres) {\n    if (stAC !== 'ligado' && temp > (set + m)) { acao = 'ligar'; razao = 'presenca_calor'; }\n    else if (stAC === 'ligado' && temp < (set - m)) { acao = 'desligar'; razao = 'presenca_frio'; }\n} else {\n    if (stAC === 'ligado' && temp < (set - m)) { acao = 'desligar'; razao = 'sem_presenca_frio'; }\n    var mins = (now - s.lastPres) / 60000;\n    if (mins >= 1 && stAC === 'ligado' && !s.done) {\n        acao = 'desligar'; razao = 'ausencia_1min';\n        s.done = true; context.set('salas', ctx);\n        node.warn(id_sala + ': AC desligado por ausência (1min)');\n    }\n}\n\nif (!acao) return null;\nreturn { topic: 'ac-iot/' + id_sala + '/comando', payload: { id_sala: id_sala, comando: acao, razao: 'automacao_' + razao } };",
    "outputs": 1,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 520,
    "y": 120,
    "wires": [
      [
        "mqtt_out_auto",
        "dbg_auto"
      ]
    ]
  },
