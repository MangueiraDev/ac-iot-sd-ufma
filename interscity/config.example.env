# Configuração do bridge InterSCity local
# O serviço recebe telemetria via HTTP e encaminha ao InterSCity remoto.

# Endereço local do serviço (Node-RED deve chamar este endereço)
LOCAL_BIND_HOST=0.0.0.0
LOCAL_BIND_PORT=5000

# Endpoint remoto InterSCity
REMOTE_API_URL=https://api.interscity.org.br
REMOTE_API_PATH=/telemetry
API_TOKEN=seu_token_aqui

# Tempo limite para requisições ao InterSCity
REMOTE_TIMEOUT=10
