# Local InterSCity bridge configuration.
# The service subscribes to AC IoT MQTT telemetry and forwards it to the
# local InterSCity Resource Adaptor REST API.

MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=ac-iot/+/sensores

INTERSCITY_CATALOGUER_URL=http://interscity-resource-cataloguer:3000
INTERSCITY_ADAPTOR_URL=http://interscity-resource-adaptor:3000
INTERSCITY_COLLECTOR_URL=http://interscity-data-collector:3000
